# ─────────────────────────────────────────────────────
# Gentera Dashboard — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────

# Google Gemini API key (required for AI Assistant)
# Get yours at: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the default Gemini model
# Default: gemini-2.0-flash (stable, multimodal, fast)
# Alternatives: gemini-1.5-flash, gemini-2.0-flash-exp, gemini-2.5-flash-preview-05-20
# VITE_GEMINI_MODEL=gemini-2.0-flash
